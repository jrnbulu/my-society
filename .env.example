# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================
# Firebase Configuration
# ============================================
FIREBASE_API_KEY=AIzaSyD_xxxxxxxxxxxxxxxxxxxxxxxxxx
FIREBASE_AUTH_DOMAIN=my-society-xxxxx.firebaseapp.com
FIREBASE_PROJECT_ID=my-society-xxxxx
FIREBASE_STORAGE_BUCKET=my-society-xxxxx.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxxxx

# ============================================
# API Configuration (Optional)
# ============================================
API_BASE_URL=https://api.example.com
API_TIMEOUT=30000

# ============================================
# App Configuration
# ============================================
APP_ENV=development
LOG_LEVEL=debug
